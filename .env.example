# ── core ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (used to build absolute media URLs).
APP_URL=http://localhost:3000
NODE_ENV=development

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/thefirm
# Set to "true" if your Postgres requires SSL (some managed providers do).
DATABASE_SSL=false

# Session cookie signing secret — use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string

# Admin login. Generate the hash with:  npm run hash-password -- 'your-password'
ADMIN_EMAIL=you@thefirm.com.br
ADMIN_PASSWORD_HASH=

# Optional shared secret guarding POST /api/cron/publish-due.
CRON_SECRET=

# ── Railway Storage Bucket (S3-compatible) ───────────────────────────────────
# Leave empty to use the local filesystem fallback (public/uploads) in dev.
RAILWAY_BUCKET=
RAILWAY_BUCKET_ENDPOINT=
RAILWAY_BUCKET_REGION=auto
RAILWAY_BUCKET_ACCESS_KEY_ID=
RAILWAY_BUCKET_SECRET_ACCESS_KEY=

# ── X / Twitter (OAuth 1.0a user context) ────────────────────────────────────
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# ── Meta (Instagram + Facebook Page) ─────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_GRAPH_VERSION=v21.0
FACEBOOK_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# ── Threads ──────────────────────────────────────────────────────────────────
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ── behaviour ────────────────────────────────────────────────────────────────
# DRY_RUN=true simulates every publish (no network calls). Keep true until the
# platform tokens above are configured and verified.
DRY_RUN=true
DEFAULT_TIMEZONE=America/Santiago
