# ============================================================
# BOOTSTRAP — APENAS estes precisam ficar no .env / Railway vars.
# São necessários ANTES do login, então não dá pra guardá-los no banco.
# Todo o resto (Gemini, Telegram, cron) você configura em /admin/settings.
# Status e instruções de cada um também ficam na página pública /setup.
# ============================================================

# Postgres. No Railway é injetado automaticamente ao criar o serviço de banco.
DATABASE_URL="postgresql://user:pass@localhost:5432/fagulha?schema=public"

# Sessão do Better Auth. Gere uma vez:  openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Chave mestra que cifra os settings operacionais no banco. Gere:  openssl rand -hex 32
# Não perca: trocar invalida tudo que já foi salvo pelo admin.
CONFIG_ENCRYPTION_KEY=""

# Login do admin (OAuth Google — DIFERENTE da GEMINI_API_KEY).
# Google Cloud → APIs & Services → Credentials → OAuth client (Web).
# Redirect URI: <APP_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ADMIN_EMAIL="zeluizr@commente.me"

# URL pública. No Railway resolve sozinho via RAILWAY_PUBLIC_DOMAIN; em local deixe assim.
APP_URL="http://localhost:3000"

# ============================================================
# OPERACIONAL — OPCIONAL aqui. O normal é configurar em /admin/settings
# (cifrado no banco). Se preencher aqui, vale como fallback do banco.
# ============================================================
# GEMINI_API_KEY=""
# GEMINI_TEXT_MODEL="gemini-flash-latest"
# GEMINI_IMAGE_MODEL="gemini-3.1-flash-image"
# GEMINI_VIDEO_MODEL="veo-3.1-fast-generate-preview"
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""
# TELEGRAM_ADMIN_ID=""
# TELEGRAM_WEBHOOK_SECRET=""
# CRON_SECRET=""
# POST_LANGUAGE="pt-BR"

# armazenamento de mídia (monte um Railway Volume em MEDIA_DIR no web service)
# MEDIA_DIR="data/uploads"
# MEDIA_PUBLIC_PATH="/uploads"
